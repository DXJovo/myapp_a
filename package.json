{
  "name": "tradingagents-fund-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --host 0.0.0.0",
    "dev:browser": "concurrently -n API,WEB -c cyan,green \"cargo run --manifest-path rust-api/Cargo.toml\" \"vite --host 0.0.0.0\"",
    "server": "cargo run --manifest-path rust-api/Cargo.toml",
    "build": "vite build",
    "desktop:build": "tauri build --no-bundle",
    "desktop:bundle": "tauri build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint ."
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "lucide-react": "^0.468.0",
    "vite": "^6.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0"
  }
}
